    {
      "name": "Convert",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status 200\", () => pm.response.to.have.status(200));\r",
              "pm.test(\"Contains EUR conversion fields\", () => {\r",
              "    const body = pm.response.json();\r",
              "    pm.expect(body).to.have.all.keys(\"ProductID\",\"Name\",\"price_usd\",\"price_eur\",\"exchange_rate\",\"rate_date\");\r",
              "    pm.expect(body.price_eur).to.be.a(\"number\");\r",
              "    pm.expect(body.exchange_rate).to.be.a(\"number\");\r",
              "    pm.expect(body.exchange_rate).to.be.above(0);\r",
              "});\r",
              "pm.test(\"EUR price is calculated correctly\", () => {\r",
              "    const body = pm.response.json();\r",
              "    const expected = Math.round(body.price_usd * body.exchange_rate * 100) / 100;\r",
              "    pm.expect(body.price_eur).to.be.closeTo(expected, 0.01);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
